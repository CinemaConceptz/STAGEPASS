{
  "expo": {
    "name": "STAGEPASS",
    "slug": "stagepassaccess",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "stagepass",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stagepassaccess.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "STAGEPASS needs microphone access for live broadcasting.",
        "NSCameraUsageDescription": "STAGEPASS needs camera access for live broadcasting.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.stagepassaccess.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "INTERNET",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow STAGEPASS to access your microphone for live broadcasting."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow STAGEPASS to access your photos to set a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "20bb8f4d-2b7b-42e9-a903-40eb76941a4d"
      }
    },
    "owner": "stagepassaccess",
    "updates": {
      "url": "https://u.expo.dev/20bb8f4d-2b7b-42e9-a903-40eb76941a4d"
    }
  }
}
